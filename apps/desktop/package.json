{
  "name": "@kreeyts/desktop",
  "private": true,
  "version": "1.0.0",
  "description": "Kreeyts desktop app.",
  "author": "Rohi <noelrohi59@gmail.com>",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun scripts/dev-electron.mjs",
    "dev:electron": "bun scripts/dev-electron.mjs",
    "dev:renderer": "vite",
    "build": "tsc && vite build && tsdown",
    "build:electron": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "dist": "bun run build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.rohi.kreeyts",
    "productName": "Kreeyts",
    "directories": {
      "output": "release/electron"
    },
    "files": ["dist/**/*", "dist-electron/**/*", "package.json"],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "dependencies": {
    "@kreeyts/desktop-bridge": "workspace:*",
    "@kreeyts/ui": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tabler/icons-react": "catalog:",
    "clsx": "catalog:",
    "radix-ui": "catalog:",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "catalog:",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@types/node": "^25.0.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "42.5.0",
    "electron-builder": "^26.8.1",
    "tsdown": "^0.21.9",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite": "^7.0.4"
  }
}
